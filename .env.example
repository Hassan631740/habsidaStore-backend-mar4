# Copy to .env and replace with your real values. Do not commit .env.
# This project uses PostgreSQL (see application.properties and pom.xml).

# Database (PostgreSQL). Use no query params; do not add useUnicode/characterEncoding (MySQL-only).
DATABASE_URL=jdbc:postgresql://localhost:5432/habsida_store
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Server (optional)
# SERVER_PORT=8080
