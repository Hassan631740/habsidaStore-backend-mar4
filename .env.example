# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Profile: local | dev | prod
SPRING_PROFILES_ACTIVE=local

# Server port
SERVER_PORT=8080

# PostgreSQL
DATABASE_URL=jdbc:postgresql://localhost:5432/habsida_store
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-database-password

# JWT: generate a strong secret for production (e.g. openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-at-least-32-bytes
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS (required for prod): comma-separated allowed origins
# Example: http://localhost:3000,https://your-frontend.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
